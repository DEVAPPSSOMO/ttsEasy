{
  "name": "tts-easy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:public:local": "node scripts/run-next-with-env-file.mjs dev .env.public.local",
    "dev:api": "node scripts/run-next-with-env-file.mjs dev .env.api.local",
    "build": "next build",
    "build:public:local": "node scripts/run-next-with-env-file.mjs build .env.public.local",
    "build:api": "node scripts/run-next-with-env-file.mjs build .env.api.local",
    "start": "next start",
    "start:public:local": "node scripts/run-next-with-env-file.mjs start .env.public.local",
    "start:api": "node scripts/run-next-with-env-file.mjs start .env.api.local",
    "deploy": "node scripts/deploy-vercel.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "growth:check:public": "node scripts/phase1-env-check.mjs public",
    "growth:check:public:local": "node scripts/phase1-env-check.mjs public .env.public.local",
    "growth:check:api": "node scripts/phase1-env-check.mjs api",
    "growth:check:api:local": "node scripts/phase1-env-check.mjs api .env.api.local",
    "billing:import-legacy-keys": "node scripts/import-legacy-api-keys.mjs",
    "billing:import-legacy-keys:api-local": "node scripts/run-node-script-with-env-file.mjs .env.api.local scripts/import-legacy-api-keys.mjs",
    "sale:check": "node scripts/sale-readiness-check.mjs"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^5.7.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@upstash/redis": "^1.35.3",
    "@vercel/analytics": "^1.3.2",
    "gray-matter": "^4.0.3",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "reading-time": "^1.5.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
