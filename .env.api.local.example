# Local API portal profile
# Copy to `.env.api.local`. The `dev:api`, `build:api`, `start:api`, and
# `growth:check:api:local` scripts load `.env`, `.env.local`, and then this file
# as an overlay so you can keep shared secrets in `.env.local`.

PORT=3200
APP_VARIANT=api
NEXT_PUBLIC_SITE_URL=http://localhost:3200
NEXT_PUBLIC_API_BASE_URL=http://localhost:3200

API_BILLING_PREPAID_ENABLED=true
API_BILLING_DB_ENABLED=true
API_BILLING_LEGACY_FALLBACK_ENABLED=true

# Required here or in `.env.local`
# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_CLOUD_CLIENT_EMAIL=
# GOOGLE_CLOUD_PRIVATE_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# API_KEY_HASH_PEPPER=
# SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_ACCOUNT_COUNTRY=ES

# Optional but typical for local Stripe checkout flows
# STRIPE_PUBLISHABLE_KEY=
